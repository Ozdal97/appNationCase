# Application
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_chat?schema=public
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Security — JWT secret must be at least 32 chars (HS256 best practice).
# Generate a strong one with:  openssl rand -base64 48
JWT_SECRET=super-secret-jwt-key-CHANGE-ME-at-least-32-chars
JWT_EXPIRES_IN=24h
FIREBASE_APP_CHECK_ENABLED=false

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Feature Flags
STREAMING_ENABLED=true
PAGINATION_LIMIT=20
AI_TOOLS_ENABLED=true
CHAT_HISTORY_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
CHAT_HISTORY_LIMITED_COUNT=10

# Admin (runtime flag flipping)
ADMIN_TOKEN=dev-admin-token

# Demo client mock-login (set to 'true' only for local demos)
DEMO_LOGIN_ENABLED=true

# AI Provider — openai (live, primary) | mock (offline fallback, no API key)
# Runs through the Vercel AI SDK (already installed).
# openai REQUIRES OPENAI_API_KEY below. Switch to mock for offline/no-key runs.
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Rate limiter persistence — memory (default, single-instance) | redis (multi-instance)
# For 'redis' install: npm i ioredis  +  set REDIS_URL
RATE_LIMIT_STORE=memory
REDIS_URL=
